# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.
# Production: rotate every credential; do NOT reuse these dev defaults.

# === App ===
PORT=3000

# === MySQL (Docker Compose) ===
# Local-dev defaults; safe to keep as-is on your machine, replace in any shared environment.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=commerce
MYSQL_USER=commerce
MYSQL_PASSWORD=change-me
MYSQL_PORT=3307

# === Prisma ===
# Must match MYSQL_USER / MYSQL_PASSWORD / MYSQL_PORT / MYSQL_DATABASE above.
# In production, set DATABASE_URL directly via the platform's secret manager.
DATABASE_URL="mysql://commerce:change-me@localhost:3307/commerce"
